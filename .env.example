# Vaultly Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vaultly
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret — change this to a long random string in production
JWT_SECRET=vaultly_super_secret_jwt_key_change_me_in_production

# Server Port
PORT=3000
